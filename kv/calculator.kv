<CalculatorScreen>:

    orientation: "vertical"

    padding: 10

    spacing: 8

    Label:

        id: mode

        text: "DEG"

        size_hint_y: .05

    Label:

        id: expression

        text: ""

        font_size: "24sp"

        halign: "right"

        text_size: self.size

        size_hint_y: .10

    Label:

        id: result

        text: "0"

        font_size: "36sp"

        halign: "right"

        text_size: self.size

        size_hint_y: .10

    GridLayout:

        cols: 5

        spacing: 5

        size_hint_y: .75

        Button:
            text: "DEG/RAD"
            on_press: root.toggle_angle_mode()

        Button:
            text: "sin"
            on_press: root.scientific("sin")

        Button:
            text: "cos"
            on_press: root.scientific("cos")

        Button:
            text: "tan"
            on_press: root.scientific("tan")

        Button:
            text: "√"
            on_press: root.scientific("sqrt")

        Button:
            text: "log"
            on_press: root.scientific("log")

        Button:
            text: "ln"
            on_press: root.scientific("ln")

        Button:
            text: "!"
            on_press: root.scientific("factorial")

        Button:
            text: "("
            on_press: root.button_pressed("(")

        Button:
            text: ")"
            on_press: root.button_pressed(")")

        Button:
            text: "7"
            on_press: root.button_pressed("7")

        Button:
            text: "8"
            on_press: root.button_pressed("8")

        Button:
            text: "9"
            on_press: root.button_pressed("9")

        Button:
            text: "÷"
            on_press: root.button_pressed("/")

        Button:
            text: "C"
            on_press: root.clear()

        Button:
            text: "4"
            on_press: root.button_pressed("4")

        Button:
            text: "5"
            on_press: root.button_pressed("5")

        Button:
            text: "6"
            on_press: root.button_pressed("6")

        Button:
            text: "×"
            on_press: root.button_pressed("*")

        Button:
            text: "⌫"
            on_press: root.backspace()

        Button:
            text: "1"
            on_press: root.button_pressed("1")

        Button:
            text: "2"
            on_press: root.button_pressed("2")

        Button:
            text: "3"
            on_press: root.button_pressed("3")

        Button:
            text: "-"
            on_press: root.button_pressed("-")

        Button:
            text: "π"
            on_press: root.button_pressed("pi")

        Button:
            text: "0"
            on_press: root.button_pressed("0")

        Button:
            text: "."
            on_press: root.button_pressed(".")

        Button:
            text: "="
            on_press: root.calculate()

        Button:
            text: "+"
            on_press: root.button_pressed("+")

        Button:
            text: "e"
            on_press: root.button_pressed("e")